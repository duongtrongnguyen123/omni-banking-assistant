# Optional: enable LLM-based NLU. Pick one provider; if neither is set, the
# rule-based pipeline handles all 6 demo scenarios on its own.
# Groq takes precedence over Gemini if both are set.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Demo user (used to scope mock data when no auth header is sent)
DEMO_USER_ID=u_an

# Optional: use the generated 6-month demo dataset instead of app/data.
# Generate it first with data/transform_banking_dataset.py.
# BANKING_DATA_DIR=../data/demo

# CORS — Vite dev server defaults
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Postgres omni (AWS RDS) + Redis cache ---
# Postgres omni chạy trên AWS RDS — dùng cho script seed (push_to_postgres.py) và
# đường đọc khi DATA_BACKEND=postgres. Trỏ tới endpoint RDS của bạn:
# DATABASE_URL=postgresql://<user>:<pass>@<your-db>.xxxx.rds.amazonaws.com:5432/omni
# Redis chạy local bằng `docker compose up -d`. Để trống = tắt cache.
# REDIS_URL=redis://localhost:6379/0
# Bật cache cho đường đọc của app + chọn nguồn dữ liệu là Postgres RDS.
# CACHE_ENABLED=false
# DATA_BACKEND=memory
# TTL cache (giây) — mặc định 300s = 5 phút.
# CACHE_TTL_SECONDS=300
