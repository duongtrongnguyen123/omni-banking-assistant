# Omni backend — environment configuration
# Copy to `.env` and edit. Everything is optional; the rule pipeline runs
# the full demo on its own with no keys configured.

# ----- LLM providers (multi-provider fallback chain) -----
# Tried in order: Groq → Gemini → rule fallback. Demo doesn't break on 429.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ----- Demo / scoping -----
DEMO_USER_ID=u_an
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Override seed dir — points at the contest-derived 1000-contact subset:
#   BANKING_DATA_DIR=../data/demo

# ----- Database -----
# Override to switch DBs at runtime (contest 520k, Czech PKDD'99, BankSim).
# OMNI_DB_PATH=app/data/omni_contest.db

# ----- Embeddings (RAG) -----
# Skip ONNX warm + lazy-fill on startup. Useful for CI and fast iteration.
# OMNI_SKIP_EMBED_BACKFILL=1

# ----- Session persistence -----
# Backend: memory (default) | redis | fake-redis (in-process, no docker)
# OMNI_SESSION_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0
# OMNI_SESSION_TTL_S=1800   # 30 min — bounds Redis memory per user
# OMNI_DRAFT_TTL_S=300      # 5 min — abandoned drafts auto-expire
# OMNI_HISTORY_MAX=20       # truncate LLM context payload

# ----- Eval knobs (scripts/eval_suggester*.py) -----
# EVAL_TEST_LIMIT=1500      # cap test set for fast iteration on 520k DBs
# EVAL_MIN_TRAIN=5          # drop test rows for cold contacts (<N train tx)
