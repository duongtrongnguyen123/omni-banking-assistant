backend/.venv/
backend/.env
backend/**/__pycache__/
backend/**/*.pyc
data/**/__pycache__/
data/**/*.pyc

frontend/node_modules/
frontend/dist/

.DS_Store
.vscode/
.idea/
*.log
.tmp_pdf_text/

# Slide deck — kept locally, not pushed
*.pdf

# Large source-derived dataset — regenerate locally with data/transform_banking_dataset.py
/data/generated/

# Contest CSV bundle — too big for git; regenerate via scripts/load_contest_full.py
/generated/
/generated.zip

# Public reference datasets — downloaded on demand by load_czech.py /
# load_banksim.py. Both are large (Czech ~55 MB, BankSim ~50 MB) and
# fetchable from public URLs documented in data/public/README.md.
/data/public/*
!/data/public/README.md

# Per-DB-file SQLite artefacts (default, contest, synthetic snapshots, demo db)
backend/app/data/omni*.db
backend/app/data/omni*.db-*
data/demo/omni.db
data/demo/omni.db-*

# A/B test bandit posterior — best-effort persistence, regenerated at runtime
backend/app/data/bandit_state.json
backend/app/data/bandit_state.tmp

# Stray seed copies — test fixtures (test_metrics, test_demo_recorder) write
# JSON seeds to BANKING_DATA_DIR. If a developer accidentally exports
# BANKING_DATA_DIR="" the shell evaluates it as set-but-empty, Path("")
# resolves to the CWD, and the seeds land at backend/ root instead of the
# tmp dir conftest.py intended. Ignore the four stray copies so the dirty
# git tree from that run-with-empty-env doesn't get committed. The
# fixtures themselves now treat empty-string as unset and fall back to
# `.tmp_test_seed/`, so this serves as belt-and-braces against an older
# checkout that still has the original fixture.
backend/contacts.json
backend/transactions.json
backend/users.json
backend/schedules.json

# Tests-local seed copy that the fallback path writes to. Auto-created
# by test_metrics / test_demo_recorder when BANKING_DATA_DIR is empty.
backend/tests/.tmp_test_seed/

.claude/
backend/.venv/
